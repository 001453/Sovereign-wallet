{
  "name": "sovereign-wallet",
  "version": "1.0.0",
  "description": "Chrome extension wallet (Manifest V3) using @tetherto/wdk",
  "scripts": {
    "icons": "node scripts/generate-icons.mjs",
    "prebuild": "node scripts/generate-icons.mjs && node scripts/fetch-token-icons.mjs",
    "icons:tokens": "node scripts/fetch-token-icons.mjs",
    "build": "webpack --config webpack.config.js",
    "dev": "webpack --config webpack.config.js --watch",
    "build:prod": "cross-env NODE_ENV=production webpack --config webpack.config.js",
    "contracts:test": "cd ../contracts && forge test",
    "contracts:build": "cd ../contracts && forge build"
  },
  "dependencies": {
    "@tetherto/wdk": "^1.0.0-beta.9",
    "@tetherto/wdk-wallet-btc": "^1.0.0-beta.9",
    "@tetherto/wdk-wallet-evm": "^1.0.0-beta.12",
    "@tetherto/wdk-wallet-solana": "^1.0.0-beta.8",
    "bip39": "^3.1.0",
    "buffer": "^6.0.3",
    "ethers": "^6.13.0",
    "process": "^0.11.10",
    "qrcode": "^1.5.4",
    "sodium-javascript": "^0.8.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.4",
    "@babel/preset-env": "^7.24.4",
    "babel-loader": "^9.1.3",
    "copy-webpack-plugin": "^14.0.0",
    "cross-env": "^7.0.3",
    "css-loader": "^7.1.1",
    "sharp": "^0.33.5",
    "style-loader": "^4.0.0",
    "webpack": "^5.91.0",
    "webpack-cli": "^5.1.4"
  }
}
